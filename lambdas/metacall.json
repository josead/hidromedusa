{
  "language_id": "node",
  "path": ".",
  "scripts": [
    "auth/index.js",
    "tickets/index.js",
    "calendar/index.js",
    "staff/index.js",
    "newsletter/index.js",
    "jellyfish/index.js"
  ],
  "endpoints": [
    { "path": "/auth/exchange",            "method": "POST", "module": "auth/index",       "fn": "exchange"    },
    { "path": "/auth/me",                  "method": "GET",  "module": "auth/index",       "fn": "me"          },

    { "path": "/tickets/request",          "method": "POST", "module": "tickets/index",    "fn": "request"     },
    { "path": "/tickets/redeem",           "method": "POST", "module": "tickets/index",    "fn": "redeem"      },
    { "path": "/tickets/issue",            "method": "POST", "module": "tickets/index",    "fn": "issue"       },
    { "path": "/tickets",                  "method": "GET",  "module": "tickets/index",    "fn": "list"        },
    { "path": "/tickets/:id/free",         "method": "POST", "module": "tickets/index",    "fn": "free"        },
    { "path": "/tickets/:id/scan",         "method": "POST", "module": "tickets/index",    "fn": "scan"        },
    { "path": "/tickets/:id",              "method": "GET",  "module": "tickets/index",    "fn": "getTicket"   },

    { "path": "/calendar/events",          "method": "GET",  "module": "calendar/index",   "fn": "getEvents"   },
    { "path": "/calendar/subscribe",       "method": "POST", "module": "calendar/index",   "fn": "subscribe"   },
    { "path": "/calendar/ics/:id",         "method": "GET",  "module": "calendar/index",   "fn": "serveIcs"    },

    { "path": "/staff/members",            "method": "GET",  "module": "staff/index",      "fn": "getMembers"  },
    { "path": "/staff/tasks",              "method": "GET",  "module": "staff/index",      "fn": "getTasks"    },
    { "path": "/staff/tasks/toggle",       "method": "POST", "module": "staff/index",      "fn": "toggleTask"  },
    { "path": "/staff/tasks/add",          "method": "POST", "module": "staff/index",      "fn": "addTask"     },
    { "path": "/staff/overview",           "method": "GET",  "module": "staff/index",      "fn": "getOverview" },

    { "path": "/newsletter/subscribe",     "method": "POST", "module": "newsletter/index", "fn": "subscribe"   },
    { "path": "/newsletter/list",          "method": "GET",  "module": "newsletter/index", "fn": "list"        },

    { "path": "/jellyfish/:noun/:adjective", "method": "GET", "module": "jellyfish/index", "fn": "serve" }
  ]
}
