# ── App ──────────────────────────────────────────
APP_URL=https://hidromedusa.com
API_URL=https://api.hidromedusa.com

# ── Google OAuth & Calendar ───────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_API_KEY=

# ── Apple Sign In ─────────────────────────────────
APPLE_CLIENT_ID=com.hidromedusa.web
APPLE_CLIENT_SECRET=

# ── Instagram Basic Display API ───────────────────
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# ── AWS / DynamoDB ────────────────────────────────
AWS_REGION=us-east-1
# Set to http://localhost:4566 for LocalStack; leave empty for real AWS.
DYNAMODB_ENDPOINT=
DDB_TABLE_PREFIX=hm_

# ── Staff ─────────────────────────────────────────
# Shared staff passphrase. Unset => all staff actions allowed in dev.
STAFF_TOKEN=

# ── Contacto (pedido de entradas) ─────────────────
# WhatsApp en E.164 sin el '+' (e.g. 5492494XXXXXX).
WHATSAPP_NUMBER=5492494481699
# Usuario de Instagram para el DM directo (ig.me/m/<handle>), sin '@'.
INSTAGRAM_HANDLE=hidromedusa
